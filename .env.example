# Copy this file to .env and adjust values if you like.
# Used by docker-compose for both PostgreSQL and the FastAPI app.

# --- AWS ECR (אופציונלי — לדחיפת תמונות עם scripts/push-ecr.ps1 או scripts/push-ecr.sh) ---
# צור ב-AWS שני מאגרים ב-ECR (למשל game-backend, game-frontend), אותה אזור כמו AWS_REGION.
# החלף ACCOUNT_ID, REGION ושמות המאגרים בערכים שלך:
# AWS_REGION=eu-west-1
# BACKEND_IMAGE=ACCOUNT_ID.dkr.ecr.REION.amazonaws.com/game-backend:latest
# FRONTEND_IMAGE=ACCOUNגT_ID.dkr.ecr.REGION.amazonaws.com/game-frontend:latest

POSTGRES_USER=notesuser
POSTGRES_PASSWORD=notespass
POSTGRES_DB=notesdb

# From insid4e Docker, the database hostname is the compose service name "db".
POSTGRES_HOST=db
POSTGRES_PORT=5432

# אופציונלי: מיפוי פורט Postgres למחשב המארח (docker compose). ברירת מחדל 5432; לדוגמה 15432 כשהפורט תפוס.
# POSTGRES_גHOST_PORT=15432

# המשחק השולחני (Pygame) מתחבר לשרת על המחשב שלך.
# ברירת מחדל: http://127.0.0.1:8000 — אין חובה להגדיר, אלא אם שינית פורט.
# SPACE_API_URL=http://127.0.0.1:8000

# פורט בכתובת המחשב ל־nginx (משחק בדפדפן). אם 9080 תפוס — שנה למשל 3000 או 8888.
# FRONTEND_PORT=9080

# Jenkins (אופציונלי, אם רוצים לשנות פורטים מקומיים).
# JENKINS_HTTP_PORT=8081
# JENKINS_AGENT_PORT=50000
# אם עדיין יש permission denied ל-docker.sock אחרי group_add ב-compose, בדוק GID:
# docker run --rm -v /var/run/docker.sock:/var/run/docker.sock alpine stat -c '%g' /var/run/docker.sock
# והוסף את המספר לרשימת group_add של שירות jenkins ב-docker-compose.yml (לפי הצורך).

# ngrok token (אופציונלי אבל מומלץ, לפי החשבון שלך ב-ngrok).
# NGROK_AUTHTOKEN=your_ngrok_authtoken_here
